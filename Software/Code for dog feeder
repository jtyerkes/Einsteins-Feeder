#include "HX711.h"

// Stepper Pins
const int stepPin = 4;
const int dirPin = 5;

// Load Cell Pins
const int doutPin = 2;
const int sckPin = 3;

HX711 scale;
float targetWeight = 150.0; // Target in grams

void setup() {
  pinMode(stepPin, OUTPUT);
  pinMode(dirPin, OUTPUT);
  
  scale.begin(doutPin, sckPin);
  scale.set_scale(-405.0); // Replace with your calibration factor
  scale.tare(); 
}

void loop() {
  float currentWeight = scale.get_units(5); // Read average weight

  if (currentWeight < targetWeight) {
    digitalWrite(dirPin, HIGH); // Set direction
    
    // One "Step"
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(800); // Adjust for speed (lower = faster)
    digitalWrite(stepPin, LOW);
    delayMicroseconds(800);
  } else {
    // Target reached! Do nothing until next feeding time
    delay(1000); 
  }
}
