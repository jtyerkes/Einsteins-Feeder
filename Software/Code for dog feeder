#include <SoftwareSerial.h>
#include "HX711.h"

// Nextion on D2(RX) and D3(TX)
SoftwareSerial nextion(2, 3); 
HX711 scale;

// Pins for A4988
const int stepPin = 6;
const int dirPin = 7;

float targetWeight = 0; // Set this via Nextion

void setup() {
  nextion.begin(9600);
  scale.begin(4, 5); // DT, SCK
  pinMode(stepPin, OUTPUT);
  pinMode(dirPin, OUTPUT);
}

void loop() {
  // 1. Check if Nextion sent a command (e.g., "Start Feeding")
  if (nextion.available()) {
    // Logic to parse the button press from the screen
  }

  // 2. Dispensing Logic
  float currentWeight = scale.get_units(5);
  
  if (isFeeding && currentWeight < targetWeight) {
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(800);
    digitalWrite(stepPin, LOW);
    delayMicroseconds(800);
    
    // 3. Update Nextion Progress
    // Only update every 500ms to avoid lagging the serial port
    updateNextionWeight(currentWeight); 
  } else {
    isFeeding = false;
  }
}
